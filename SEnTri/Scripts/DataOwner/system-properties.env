##System config
VERSION=1.0
QUERY_ENGINE=pt.fct.nova.id.srv.application.query.SPARQLQueryEngine
STORAGE_ENGINE=pt.fct.nova.id.srv.application.storage.redis.RStorageEngine
### TLS config
TLS_VERSION=TLSv1.3
TLS_CIPHER_SUITES=TLS_CHACHA20_POLY1305_SHA256
### Routes
TRIPLESTORE_URI=https://localhost:8080/Triplestore/
### Triplestore API
CREATE_TRIPLESTORE_PATH=api/plain/create/%s
UPLOAD_TRIPLESTORE_PATH=api/plain/upload/%s
DELETE_TRIPLESTORE_PATH=api/plain/delete/%s
QUERY_TRIPLESTORE_PATH=api/plain/query/%s
### Secure Triplestore API
SECURE_CREATE_TRIPLESTORE_PATH=api/secure/create/%s
SECURE_UPLOAD_TRIPLESTORE_PATH=api/secure/upload/%s
SECURE_DELETE_TRIPLESTORE_PATH=api/secure/delete/%s