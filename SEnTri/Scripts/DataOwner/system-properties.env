##System config
VERSION=2.0
### TLS config
TLS_VERSION=TLSv1.3
TLS_CIPHER_SUITES=TLS_CHACHA20_POLY1305_SHA256,TLS_AES_256_GCM_SHA384,TLS_AES_128_GCM_SHA256
### Routes
TRIPLESTORE_URI=https://sentri-triplestore-api:8443/Triplestore/api/
### Triplestore API
CREATE_TRIPLESTORE_PATH=triplestore/create/%s
UPLOAD_TRIPLESTORE_PATH=triplestore/upload/%s
DELETE_TRIPLESTORE_PATH=triplestore/delete/%s
QUERY_TRIPLESTORE_PATH=triplestore/query/%s
### Secure Triplestore API
SECURE_CREATE_TRIPLESTORE_PATH=secure-triplestore/create/%s
SECURE_UPLOAD_TRIPLESTORE_PATH=secure-triplestore/upload/%s
SECURE_DELETE_TRIPLESTORE_PATH=secure-triplestore/delete/%s