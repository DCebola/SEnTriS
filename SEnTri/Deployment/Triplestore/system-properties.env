# System configs
## System Variables
VERSION=2.0
COMPOUND_IRI_SEPARATOR=‚Äñ
BASIC_SEPARATOR=‚¨ù
IRI_SEPARATOR=‚ó¶
## Redis config
REDIS_HOST=sentri-triplestore-db
REDIS_PORT=6379
REDIS_TIMEOUT=1000
REDIS_MAX_TOTAL=128
REDIS_MAX_IDLE=128
REDIS_MIN_IDLE=16
REDIS_TEST_ON_BORROW=true
REDIS_TEST_ON_RETURN=true
REDIS_TEST_WHILE_IDLE=true
REDIS_TESTS_PER_EVICTION_RUN=3
REDIS_BLOCK_WHEN_EXHAUSTED=true
## Cryptographic configs
### TLS
TLS_VERSION=TLSv1.3
TLS_CIPHER_SUITES=TLS_CHACHA20_POLY1305_SHA256,TLS_AES_256_GCM_SHA384,TLS_AES_128_GCM_SHA256

# HTTP configs
CLIENT_CONN_POOL_MAX_TOTAL=200
CLIENT_CONN_POOL_MAX_PER_ROUTE=20
## IAM API routes
IAM_PROVIDER_URI=https://sentri-iam-provider-api:8443/IAMProvider/api
### Access permissions check
IAM_PROVIDER_CHECK_READ_ACCESS_URI=${IAM_PROVIDER_URI}/triplestores/%s/access/tokens/read
IAM_PROVIDER_CHECK_WRITE_ACCESS_URI=${IAM_PROVIDER_URI}/triplestores/%s/access/tokens/write
IAM_PROVIDER_CHECK_OWNER_ACCESS_URI=${IAM_PROVIDER_URI}/triplestores/%s/access/tokens/owner

## Proxy API routes
PROXY_URI=https://sentri-proxy-api:8443/Proxy/api
PROXY_PREPARE_SEARCH_URI=${PROXY_URI}/queries/prepare