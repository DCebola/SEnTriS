# System configs
## System Variables
VERSION=2.0
BASIC_SEPARATOR=:
## Redis config
REDIS_HOST=sentri-vault-db
REDIS_PORT=6379
REDIS_TIMEOUT=1000
REDIS_MAX_TOTAL=128
REDIS_MAX_IDLE=128
REDIS_MIN_IDLE=16
REDIS_TEST_ON_BORROW=true
REDIS_TEST_ON_RETURN=true
REDIS_TEST_WHILE_IDLE=true
REDIS_TESTS_PER_EVICTION_RUN=3
REDIS_BLOCK_WHEN_EXHAUSTED=true
## Cryptographic configs
### TLS
TLS_VERSION=TLSv1.3
TLS_CIPHER_SUITES=TLS_CHACHA20_POLY1305_SHA256,TLS_AES_256_GCM_SHA384,TLS_AES_128_GCM_SHA256

## Vault configs
### Locks
LOCK_LIFETIME=1800 #30mins
LOCK_TRIES=3 #30mins
LOCK_SLEEP=300 #5mins

# HTTP configs
DOMAIN=localhost
## IAM API routes
IAM_PROVIDER_URI=https://sentri-iam-provider-api:8443/IAMProvider/api
### Access permissions check
IAM_PROVIDER_CHECK_READ_ACCESS_URI=${IAM_PROVIDER_URI}/api/triplestores/%s/access/tokens/read
IAM_PROVIDER_CHECK_OWNER_ACCESS_URI=${IAM_PROVIDER_URI}/api/triplestores/%s/access/tokens/owner