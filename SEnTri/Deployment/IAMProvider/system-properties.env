# System configs
## System Variables
VERSION=2.0
BASIC_SEPARATOR=:
## Redis configs
REDIS_HOST=sentri-iam-provider-db
REDIS_PORT=6379
REDIS_TIMEOUT=1000
REDIS_MAX_TOTAL=128
REDIS_MAX_IDLE=128
REDIS_MIN_IDLE=16
REDIS_TEST_ON_BORROW=true
REDIS_TEST_ON_RETURN=true
REDIS_TEST_WHILE_IDLE=true
REDIS_TESTS_PER_EVICTION_RUN=3
REDIS_BLOCK_WHEN_EXHAUSTED=true
## Cryptographic configs
### TLS
TLS_VERSION=TLSv1.3
TLS_CIPHER_SUITES=TLS_CHACHA20_POLY1305_SHA256,TLS_AES_256_GCM_SHA384,TLS_AES_128_GCM_SHA256
### Password
PASSWORD_KEY_ALGORITHM=PBKDF2WithHmacSHA1
SALT_LENGTH=32
PASSWORD_HASH_LENGTH=256
PASSWORD_HASHING_ITERATIONS=10000

## IAM configs
DOMAIN=localhost
### Default Admin
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin
### Session
SESSION_LIFETIME=7200 #2h
### Access Token
ACCESS_TOKEN_LIFETIME=3600 #1h
### Locks
LOCK_LIFETIME=1800 #30mins
LOCK_TRIES=3 #30mins
LOCK_SLEEP=300 #5mins