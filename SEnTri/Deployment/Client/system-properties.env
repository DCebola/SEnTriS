# System configs
## System Variables
VERSION=2.0
IRI_SEPARATOR=:
## Cryptographic configs
### TLS
TLS_VERSION=TLSv1.3
TLS_CIPHER_SUITES=TLS_CHACHA20_POLY1305_SHA256,TLS_AES_256_GCM_SHA384,TLS_AES_128_GCM_SHA256
### SE protocols
KEYWORD_SEPARATOR=:
SECRETS_PROTOCOL_VERSION=version
SECRETS_PROTOCOL_KEY=key_%s
SECRETS_PROTOCOL_IV=iv
### Symmetric Encryption Algorithms config
#### Chacha20-Poly1305
SYMMETRIC_KEY_ALGORITHM=ChaCha20
CIPHER_TRANSFORMATION=ChaCha20-Poly1305/None/NoPadding
SYMMETRIC_KEY_SIZE=256
SYMMETRIC_IV_SIZE=24
#### AES GCM config
#SYMMETRIC_KEY_ALGORITHM=AES
#CIPHER_TRANSFORMATION=AES/GCM/NoPadding
#SYMMETRIC_KEY_SIZE=256
#SYMMETRIC_IV_SIZE=12
#### DGK config
DGK_L=16
DGK_T=160
DGK_K=2048
DGK_R=2


# HTTP configs
COOKIE_LIFETIME=21600 # 6h (in mins)
## IAM API routes
### Users
IAM_PROVIDER_AUTH_URI=https://sentri-iam-provider-api:8443/Triplestore/api/users/auth
IAM_PROVIDER_REGISTER_USER_URI=https://sentri-iam-provider-api:8443/Triplestore/api/users
IAM_PROVIDER_DELETE_USER_URI=https://sentri-iam-provider-api:8443/Triplestore/api/users/%s/
IAM_PROVIDER_ISSUE_ROLE_REQUEST_URI=https://sentri-iam-provider-api:8443/Triplestore/api/users/%s/role/requests
### Stores 
IAM_PROVIDER_CREATE_STORE_URI=https://sentri-iam-provider-api:8443/Triplestore/api/stores/
IAM_PROVIDER_LIST_STORES_URI=https://sentri-iam-provider-api:8443/Triplestore/api/stores/%s
IAM_PROVIDER_DELETE_STORE_URI=https://sentri-iam-provider-api:8443/Triplestore/api/stores/%s
IAM_PROVIDER_GRANT_ACCESS_URI=https://sentri-iam-provider-api:8443/Triplestore/api/stores/%s/access/%s
IAM_PROVIDER_REVOKE_ACCESS_URI=https://sentri-iam-provider-api:8443/Triplestore/api/stores/%s/access/%s
IAM_PROVIDER_REQUEST_ACCESS_URI=https://sentri-iam-provider-api:8443/Triplestore/api/stores/%s/access/requests
IAM_PROVIDER_CREATE_ACCESS_TOKEN_URI=https://sentri-iam-provider-api:8443/Triplestore/stores/api/%s/access/tokens/%s
IAM_PROVIDER_ACQUIRE_LOCK_URI=https://sentri-iam-provider-api:8443/Triplestore/api/stores/%s/access/locks
IAM_PROVIDER_RELEASE_LOCK_URI=https://sentri-iam-provider-api:8443/Triplestore/api/stores/%s/access/locks

## Vault API routes
VAULT_CREATE_SECRETS_URI=https://sentri-vault-api:8443/Triplestore/api/
VAULT_GET_SECRETS_URI=https://sentri-vault-api:8443/Triplestore/api/
VAULT_DELETE_SECRETS_URI=https://sentri-vault-api:8443/Triplestore/api/

## Triplestore API routes
### Non-Encrypted triplestores
TRIPLESTORE_UPLOAD_URI=https://sentri-triplestore-api:8443/Triplestore/api/%s
TRIPLESTORE_DELETE_ALL_URI=https://sentri-triplestore-api:8443/Triplestore/api/%s
TRIPLESTORE_DELETE_SOME_URI=https://sentri-triplestore-api:8443/Triplestore/api/%s/delete
TRIPLESTORE_QUERY_URI=https://sentri-triplestore-api:8443/Triplestore/api/query/%s
### Encrypted triplestores
SECURE_TRIPLESTORE_UPLOAD_URI=https://sentri-triplestore-api:8443/Triplestore/api/secure/%s
SECURE_TRIPLESTORE_DELETE_ALL_URI=https://sentri-triplestore-api:8443/Triplestore/api/secure/%s
SECURE_TRIPLESTORE_DELETE_SOME_URI=https://sentri-triplestore-api:8443/Triplestore/api/secure/%s/delete
SECURE_TRIPLESTORE_SEARCH_URI=https://sentri-triplestore-api:8443/Triplestore/api/secure/%s/search
SECURE_TRIPLESTORE_QUERY_URI=https://sentri-triplestore-api:8443/Triplestore/api/query/secure/%s