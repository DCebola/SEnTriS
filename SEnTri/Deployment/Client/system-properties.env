# System configs
## System Variables
VERSION=2.0
BASIC_SEPARATOR=:
IRI_SEPARATOR=<:>
## Cryptographic configs
### TLS
TLS_VERSION=TLSv1.3
TLS_CIPHER_SUITES=TLS_CHACHA20_POLY1305_SHA256,TLS_AES_256_GCM_SHA384,TLS_AES_128_GCM_SHA256
### SE protocols
KEYWORD_SEPARATOR=:
SECRETS_PROTOCOL_VERSION=version
SECRETS_PROTOCOL_KEY=key_%s
SECRETS_PROTOCOL_IV=iv
### Symmetric Encryption Algorithms config
#### Chacha20-Poly1305
SYMMETRIC_KEY_ALGORITHM=ChaCha20
CIPHER_TRANSFORMATION=ChaCha20-Poly1305/None/NoPadding
SYMMETRIC_KEY_SIZE=256
SYMMETRIC_IV_SIZE=12
#### AES GCM config
#SYMMETRIC_KEY_ALGORITHM=AES
#CIPHER_TRANSFORMATION=AES/GCM/NoPadding
#SYMMETRIC_KEY_SIZE=256
#SYMMETRIC_IV_SIZE=12
#### DGK config
DGK_L=16
DGK_T=160
DGK_K=2048
DGK_R=2


# HTTP configs
CLIENT_CONN_POOL_MAX_TOTAL=200
CLIENT_CONN_POOL_MAX_PER_ROUTE=20
DOMAIN=localhost
## IAM API routes
IAM_PROVIDER_URI=https://sentri-iam-provider-api:8443/IAMProvider/api
### Users
IAM_PROVIDER_AUTH_URI=${IAM_PROVIDER_URI}/users/auth
IAM_PROVIDER_REGISTER_USER_URI=${IAM_PROVIDER_URI}/users
IAM_PROVIDER_DELETE_USER_URI=${IAM_PROVIDER_URI}/users/%s/
IAM_PROVIDER_ISSUE_ROLE_REQUEST_URI=${IAM_PROVIDER_URI}/users/%s/role/requests
IAM_PROVIDER_LIST_PENDING_ROLE_REQUESTS_URI=${IAM_PROVIDER_URI}/users/%s/role/requests
IAM_PROVIDER_PROCESS_ROLE_REQUEST_URI=${IAM_PROVIDER_URI}/users/%s/role/requests/%s

### Triplestores
IAM_PROVIDER_CREATE_TRIPLESTORE_URI=${IAM_PROVIDER_URI}/triplestores/
IAM_PROVIDER_LIST_TRIPLESTORES_URI=${IAM_PROVIDER_URI}/triplestores/%s
IAM_PROVIDER_DELETE_TRIPLESTORE_URI=${IAM_PROVIDER_URI}/triplestores/%s
IAM_PROVIDER_UPDATE_TRIPLESTORE_OWNER_URI=${IAM_PROVIDER_URI}/triplestores/%s/owner/%s 

IAM_PROVIDER_LIST_USERS_WITH_ACCESS=${IAM_PROVIDER_URI}/triplestores/%s/access/users 
IAM_PROVIDER_GRANT_ACCESS_URI=${IAM_PROVIDER_URI}/triplestores/%s/access/%s
IAM_PROVIDER_REVOKE_ACCESS_URI=${IAM_PROVIDER_URI}/triplestores/%s/access/%s
IAM_PROVIDER_REQUEST_ACCESS_URI=${IAM_PROVIDER_URI}/triplestores/%s/access/requests/%s
IAM_PROVIDER_LIST_PENDING_ACCESS_REQUESTS=${IAM_PROVIDER_URI}/triplestores/%s/access/requests
IAM_PROVIDER_PROCESS_ACCESS_REQUEST=${IAM_PROVIDER_URI}/triplestores/%s/access/requests/%s

IAM_PROVIDER_CREATE_ACCESS_TOKEN_URI=${IAM_PROVIDER_URI}/triplestores/%s/access/tokens/%s
IAM_PROVIDER_DELETE_ACCESS_TOKEN_URI=${IAM_PROVIDER_URI}/triplestores/%s/access/tokens

IAM_PROVIDER_CREATE_EXPIRABLE_ACCESS_TOKEN_URI=${IAM_PROVIDER_URI}/triplestores/%s/access/expirable-tokens

IAM_PROVIDER_ACQUIRE_TRIPLESTORE_LOCK_URI=${IAM_PROVIDER_URI}/triplestores/%s/access/locks
IAM_PROVIDER_RELEASE_TRIPLESTORE_LOCK_URI=${IAM_PROVIDER_URI}/triplestores/%s/access/locks

## Vault API routes
VAULT_URI=https://sentri-vault-api:8443/Vault/api
VAULT_CREATE_SECRETS_URI=${VAULT_URI}/secrets/%s
VAULT_GET_SECRETS_URI=${VAULT_URI}/secrets/%s
VAULT_DELETE_SECRETS_URI=${VAULT_URI}/secrets/%s

## Triplestore API routes
### Non-Encrypted triplestores
TRIPLESTORE_URI=https://sentri-triplestore-api:8443/Triplestore/api
TRIPLESTORE_UPLOAD_URI=${TRIPLESTORE_URI}/%s
TRIPLESTORE_DELETE_ALL_URI=${TRIPLESTORE_URI}/%s
TRIPLESTORE_DELETE_SOME_URI=${TRIPLESTORE_URI}/%s/delete
TRIPLESTORE_QUERY_URI=${TRIPLESTORE_URI}/query/%s
### Encrypted triplestores
ENCRYPTED_TRIPLESTORE_UPLOAD_URI=${TRIPLESTORE_URI}/encrypted/%s
ENCRYPTED_TRIPLESTORE_DELETE_ALL_URI=${TRIPLESTORE_URI}/encrypted/%s
ENCRYPTED_TRIPLESTORE_DELETE_SOME_URI=${TRIPLESTORE_URI}/encrypted/%s/delete
ENCRYPTED_TRIPLESTORE_SEARCH_URI=${TRIPLESTORE_URI}/encrypted/%s/search
ENCRYPTED_TRIPLESTORE_PREPARE_SEARCH_URI=${TRIPLESTORE_URI}/encrypted/proxy/%s/search

## Proxy API routes
PROXY_URI=https://sentri-proxy-api:8443/Proxy/api
PROXY_QUERY_URI=${PROXY_URI}/queries