# System configs
## System Variables
VERSION=2.0
IRI_SEPARATOR=:
## Cryptographic configs
### TLS
TLS_VERSION=TLSv1.3
TLS_CIPHER_SUITES=TLS_CHACHA20_POLY1305_SHA256,TLS_AES_256_GCM_SHA384,TLS_AES_128_GCM_SHA256
### SE protocols
KEYWORD_SEPARATOR=:
SECRETS_PROTOCOL_VERSION=version
SECRETS_PROTOCOL_KEY=key_%s
SECRETS_PROTOCOL_IV=iv
### Symmetric Encryption Algorithms config
#### Chacha20-Poly1305
SYMMETRIC_KEY_ALGORITHM=ChaCha20
CIPHER_TRANSFORMATION=ChaCha20-Poly1305/None/NoPadding
SYMMETRIC_KEY_SIZE=256
SYMMETRIC_IV_SIZE=24
#### AES GCM config
#SYMMETRIC_KEY_ALGORITHM=AES
#CIPHER_TRANSFORMATION=AES/GCM/NoPadding
#SYMMETRIC_KEY_SIZE=256
#SYMMETRIC_IV_SIZE=12
#### DGK config
DGK_L=16
DGK_T=160
DGK_K=2048
DGK_R=2


# HTTP configs
COOKIE_LIFETIME=21600 # 6h (in mins)
## IAM API routes
### Users
IAM_PROVIDER_AUTH_URI=https://sentri-iam-provider-api:8443/IAMProvider/api/users/auth
IAM_PROVIDER_REGISTER_USER_URI=https://sentri-iam-provider-api:8443/IAMProvider/api/users
IAM_PROVIDER_DELETE_USER_URI=https://sentri-iam-provider-api:8443/IAMProvider/api/users/%s/
IAM_PROVIDER_ISSUE_ROLE_REQUEST_URI=https://sentri-iam-provider-api:8443/IAMProvider/api/users/%s/role/requests
IAM_PROVIDER_LIST_PENDING_ROLE_REQUESTS=https://sentri-iam-provider-api:8443/IAMProvider/api/users/%s/role/requests
IAM_PROVIDER_PROCESS_ROLE_REQUEST=https://sentri-iam-provider-api:8443/IAMProvider/api/users/%s/role/requests/%s
### Stores 
IAM_PROVIDER_CREATE_TRIPLESTORE_URI=https://sentri-iam-provider-api:8443/IAMProvider/api/triplestores/
IAM_PROVIDER_LIST_TRIPLESTORES_URI=https://sentri-iam-provider-api:8443/IAMProvider/api/triplestores/%s
IAM_PROVIDER_DELETE_TRIPLESTORE_URI=https://sentri-iam-provider-api:8443/IAMProvider/api/triplestores/%s
IAM_PROVIDER_UPDATE_TRIPLESTORE_OWNER_URI=https://sentri-iam-provider-api:8443/IAMProvider/api/triplestores/%s/owner/%s 

IAM_PROVIDER_LIST_USERS_WITH_ACCESS=https://sentri-iam-provider-api:8443/IAMProvider/api/triplestores/access/users 
IAM_PROVIDER_GRANT_ACCESS_URI=https://sentri-iam-provider-api:8443/IAMProvider/api/triplestores/%s/access/%s
IAM_PROVIDER_REVOKE_ACCESS_URI=https://sentri-iam-provider-api:8443/IAMProvider/api/triplestores/%s/access/%s
IAM_PROVIDER_REQUEST_ACCESS_URI=https://sentri-iam-provider-api:8443/IAMProvider/api/triplestores/%s/access/requests
IAM_PROVIDER_LIST_PENDING_ACCESS_REQUESTS=https://sentri-iam-provider-api:8443/IAMProvider/api/triplestores/%s/access/requests
IAM_PROVIDER_PROCESS_ACCESS_REQUEST=https://sentri-iam-provider-api:8443/IAMProvider/api/triplestores/%s/access/requests/%s

IAM_PROVIDER_CREATE_ACCESS_TOKEN_URI=https://sentri-iam-provider-api:8443/IAMProvider/triplestores/api/%s/access/tokens/%s
IAM_PROVIDER_DELETE_ACCESS_TOKEN_URI=https://sentri-iam-provider-api:8443/IAMProvider/triplestores/api/%s/access/tokens

IAM_PROVIDER_ACQUIRE_TRIPLESTORE_LOCK_URI=https://sentri-iam-provider-api:8443/IAMProvider/api/triplestores/%s/access/locks
IAM_PROVIDER_RELEASE_TRIPLESTORE_LOCK_URI=https://sentri-iam-provider-api:8443/IAMProvider/api/triplestores/%s/access/locks

## Vault API routes
VAULT_CREATE_SECRETS_URI=https://sentri-vault-api:8443/Vault/api/secrets/%s
VAULT_GET_SECRETS_URI=https://sentri-vault-api:8443/Vault/api/secrets/%s
VAULT_DELETE_SECRETS_URI=https://sentri-vault-api:8443/Vault/api/secrets/%s

## Triplestore API routes
### Non-Encrypted triplestores
TRIPLETRIPLESTORE_UPLOAD_URI=https://sentri-triplestore-api:8443/Triplestore/api/%s
TRIPLETRIPLESTORE_DELETE_ALL_URI=https://sentri-triplestore-api:8443/Triplestore/api/%s
TRIPLETRIPLESTORE_DELETE_SOME_URI=https://sentri-triplestore-api:8443/Triplestore/api/%s/delete
TRIPLETRIPLESTORE_QUERY_URI=https://sentri-triplestore-api:8443/Triplestore/api/query/%s
### Encrypted triplestores
SECURE_TRIPLETRIPLESTORE_UPLOAD_URI=https://sentri-triplestore-api:8443/Triplestore/api/secure/%s
SECURE_TRIPLETRIPLESTORE_DELETE_ALL_URI=https://sentri-triplestore-api:8443/Triplestore/api/secure/%s
SECURE_TRIPLETRIPLESTORE_DELETE_SOME_URI=https://sentri-triplestore-api:8443/Triplestore/api/secure/%s/delete
SECURE_TRIPLETRIPLESTORE_SEARCH_URI=https://sentri-triplestore-api:8443/Triplestore/api/secure/%s/search
SECURE_TRIPLETRIPLESTORE_QUERY_URI=https://sentri-triplestore-api:8443/Triplestore/api/query/secure/%s