VERSION=1.0
REDIS_TIMEOUT=1000
REDIS_MAX_TOTAL=128
REDIS_MAX_IDLE=128
REDIS_MIN_IDLE=16
REDIS_TEST_ON_BORROW=true
REDIS_TEST_ON_RETURN=true
REDIS_TEST_WHILE_IDLE=true
REDIS_TESTS_PER_EVICTION_RUN=3
REDIS_BLOCK_WHEN_EXHAUSTED=true
QUERY_ENGINE=pt.fct.nova.id.srv.application.query.SPARQLQueryEngine
STORAGE_ENGINE=pt.fct.nova.id.srv.application.storage.StorageEngine
