# System configs
## System Variables
VERSION=2.0
BASIC_SEPARATOR=:
COMPOUND_INDEX_SEPARATOR=<:>
IRI_SEPARATOR=<:>
SEARCH_DATA_LIFETIME=300 #5mins
## Redis config
REDIS_HOST=sentris-proxy-db
REDIS_PORT=6379
REDIS_TIMEOUT=86400000
REDIS_MAX_TOTAL=256
REDIS_MAX_IDLE=256
REDIS_MIN_IDLE=64
REDIS_TEST_ON_BORROW=true
REDIS_TEST_ON_RETURN=true
REDIS_TEST_WHILE_IDLE=true
REDIS_TESTS_PER_EVICTION_RUN=3
REDIS_BLOCK_WHEN_EXHAUSTED=true
## Cryptographic configs
### TLS
TLS_VERSION=TLSv1.3
TLS_CIPHER_SUITES=TLS_CHACHA20_POLY1305_SHA256,TLS_AES_256_GCM_SHA384,TLS_AES_128_GCM_SHA256
### Symmetric Encryption Algorithms config
#### Chacha20-Poly1305
SYMMETRIC_KEY_ALGORITHM=ChaCha20
CIPHER_TRANSFORMATION=ChaCha20-Poly1305/None/NoPadding
SYMMETRIC_IV_SIZE=12

# HTTP configs
CLIENT_CONN_POOL_MAX_TOTAL=200
CLIENT_CONN_POOL_MAX_PER_ROUTE=20
## IAM API routes
### Access permissions check
IAM_PROVIDER_URI=https://sentris-iam-provider-api:8443/IAMProvider/api
IAM_PROVIDER_CHECK_ACTIVE_URI=${IAM_PROVIDER_URI}/users/tokens/active